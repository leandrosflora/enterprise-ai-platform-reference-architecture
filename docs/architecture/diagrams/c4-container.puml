@startuml

!include <C4/C4_Container>

LAYOUT_WITH_LEGEND()
title Enterprise AI Platform - Container Diagram

Person(businessUser, "Business User")
Person(developer, "Developer")
Person(aiArchitect, "AI Architect")

System_Ext(foundationModels, "Foundation Models", "Bedrock, OpenAI, Anthropic e outros provedores aprovados")
System_Ext(corporateSystems, "Corporate Systems", "ERP, CRM, Core Banking, Legacy e APIs internas")
System_Ext(identityProvider, "Identity Provider", "OIDC, SSO, IAM e workload identity")
System_Ext(observabilityStack, "Observability Stack", "Logs, métricas, traces e alertas")

System_Boundary(platform, "Enterprise AI Platform") {

    Container(aiPortal, "AI Portal", "React", "Self-service para catálogo, testes, governança e operação")

    Container_Boundary(controlPlane, "Control Plane") {
        Container(agentRegistry, "Agent Registry", ".NET", "Catálogo, versões imutáveis e ciclo de vida")
        Container(governanceService, "Governance Service", ".NET", "Workflow, evidências, segregação de funções e publicação")
        Container(evaluationService, "Evaluation Service", ".NET / Python", "Datasets, baselines, quality gates e relatórios")
        Container(mcpRegistry, "MCP Registry", ".NET", "Catálogo e versões aprovadas de tools")
        Container(policyAdmin, "Policy Administration", "OPA / Cedar / Custom", "Autoria, revisão e publicação de políticas")
        Container(modelCatalog, "Model Catalog", ".NET", "Allowlist de modelos, regiões, capacidades e restrições")
    }

    Container_Boundary(dataPlane, "Data Plane") {
        Container(agentGateway, "Agent Gateway", ".NET", "Autenticação, autorização inicial, rate limit e roteamento")
        Container(agentRuntime, "Agent Runtime", ".NET / LangGraph / Semantic Kernel", "Orquestra prompts, memória, RAG, tools e modelos")
        Container(policyDecision, "Policy Decision Point", "OPA / Cedar / Custom", "Decisão de política de baixa latência")
        Container(modelGateway, "Model Gateway", ".NET", "Roteamento, quotas, guardrails, fallback e telemetria de modelos")
        Container(knowledgeService, "Knowledge Service", ".NET", "Ingestão, ACL por documento/chunk, embeddings e retrieval")
        Container(memoryService, "Memory Service", ".NET", "Memória com TTL, consentimento, isolamento e descarte")
        Container(mcpExecution, "MCP Execution", ".NET / MCP", "Execução de tools com idempotência e auditoria")
    }

    Container(auditService, "Audit Service", ".NET", "Trilha imutável de decisões e execuções")
    Container(billingService, "Billing Service", ".NET", "Tokens, custo, quotas, chargeback e showback")

    ContainerDb(postgres, "PostgreSQL", "Relational Database", "Metadados do control plane")
    ContainerDb(mongo, "MongoDB", "Document Database", "Memória e contexto flexível")
    ContainerDb(openSearch, "OpenSearch", "Vector Search", "Índices vetoriais e busca híbrida")
    ContainerDb(redis, "Redis", "Cache", "Sessão, rate limit e políticas publicadas")
    ContainerQueue(kafka, "Kafka", "Event Streaming", "Eventos versionados, auditoria e processamento assíncrono")
}

Rel(businessUser, aiPortal, "Usa")
Rel(developer, aiPortal, "Registra e testa agentes")
Rel(aiArchitect, aiPortal, "Revisa arquitetura e governança")

Rel(aiPortal, agentGateway, "Invoca agentes", "HTTPS")
Rel(aiPortal, agentRegistry, "Gerencia catálogo", "HTTPS")
Rel(aiPortal, governanceService, "Submete e revisa", "HTTPS")

Rel(agentGateway, identityProvider, "Valida identidade", "OIDC")
Rel(agentGateway, policyDecision, "Solicita decisão", "HTTPS/mTLS")
Rel(agentGateway, agentRuntime, "Encaminha invocação", "HTTPS/mTLS")

Rel(agentRuntime, agentRegistry, "Carrega versão publicada", "HTTPS/mTLS")
Rel(agentRuntime, policyDecision, "Avalia agente e contexto", "HTTPS/mTLS")
Rel(agentRuntime, knowledgeService, "Recupera conhecimento", "HTTPS/mTLS")
Rel(agentRuntime, memoryService, "Lê e grava memória", "HTTPS/mTLS")
Rel(agentRuntime, mcpRegistry, "Descobre tools aprovadas", "HTTPS/mTLS")
Rel(agentRuntime, mcpExecution, "Executa tools", "MCP")
Rel(agentRuntime, modelGateway, "Solicita inferência", "HTTPS/mTLS")
Rel(agentRuntime, evaluationService, "Submete avaliação", "Async/HTTPS")

Rel(modelGateway, modelCatalog, "Consulta modelos aprovados", "HTTPS/mTLS")
Rel(modelGateway, policyDecision, "Avalia modelo, região e budget", "HTTPS/mTLS")
Rel(modelGateway, foundationModels, "Executa inferência", "HTTPS")
Rel(mcpExecution, corporateSystems, "Executa operações", "HTTPS/MCP")

Rel(policyAdmin, policyDecision, "Publica bundles versionados", "Eventos/HTTPS")
Rel(governanceService, agentRegistry, "Aprova e publica versões", "HTTPS/Eventos")

Rel(agentRegistry, postgres, "Persiste metadados")
Rel(governanceService, postgres, "Persiste decisões e evidências")
Rel(modelCatalog, postgres, "Persiste catálogo de modelos")
Rel(knowledgeService, openSearch, "Indexa e consulta")
Rel(memoryService, mongo, "Persiste memória")
Rel(agentGateway, redis, "Rate limit e cache")
Rel(policyDecision, redis, "Cache de políticas")

Rel(agentRuntime, kafka, "Publica eventos")
Rel(modelGateway, kafka, "Publica uso e custo")
Rel(knowledgeService, kafka, "Publica eventos")
Rel(governanceService, kafka, "Publica eventos")
Rel(kafka, auditService, "Consome eventos")
Rel(kafka, evaluationService, "Consome avaliações")
Rel(kafka, billingService, "Consome uso")

Rel(agentRuntime, observabilityStack, "Exporta telemetria", "OTLP")
Rel(modelGateway, observabilityStack, "Exporta telemetria", "OTLP")
Rel(auditService, observabilityStack, "Exporta sinais operacionais")

@enduml
